meta {
  name: 1. Get My Cart
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/Cart/mycart
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
}

tests {
  test("get cart returns cart object", function () {
    expect(res.getStatus()).to.be.within(200, 299);
    const body = res.getBody();
    expect(body).to.be.an("object");
    expect(body).to.have.property("cartItems");
  });
}

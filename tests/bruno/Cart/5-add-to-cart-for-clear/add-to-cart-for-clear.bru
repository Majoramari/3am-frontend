meta {
  name: 5. Add to Cart (Prep for Clear)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/Cart/items
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "product_Id": {{productId}},
    "quantity": 1
  }
}

tests {
  test("prep add for clear returns success", function () {
    expect(res.getStatus()).to.be.within(200, 299);
  });
}

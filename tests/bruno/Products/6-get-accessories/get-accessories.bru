meta {
  name: 6. Get Accessories
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/Product/accessories
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
}

tests {
  test("get accessories returns array", function () {
    expect(res.getStatus()).to.be.within(200, 299);
    expect(res.getBody()).to.be.an("array");
  });
}

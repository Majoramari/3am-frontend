meta {
  name: 2. Payment Callback
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/payment/callback
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "invoiceId": "{{invoiceId}}"
  }
}

tests {
  test("payment callback does not return server error", function () {
    const status = res.getStatus();
    expect(status).to.be.lessThan(500);
  });
}
